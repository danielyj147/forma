# Anthropic API key — used by local ingestion (schema generation, table summaries)
# and by evals. The deployed Worker gets this via `wrangler secret put`.
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret protecting the /api/admin/ingest endpoint of a deployed env.
# Generate with: openssl rand -hex 32
INGEST_TOKEN=

# Base URL of the environment the ingestion/eval CLIs talk to.
# Local dev: http://localhost:8787  Deployed: https://<your-demo-hostname>
FORMA_API_URL=http://localhost:8787

# Optional custom hostnames for deploys (must be on a zone in your Cloudflare
# account). Leave unset to deploy on *.workers.dev only.
# DEPLOY_DOMAIN_DEMO=forma-demo.example.com
# DEPLOY_DOMAIN_PROD=forma.example.com
